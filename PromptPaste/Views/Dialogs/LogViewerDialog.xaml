<Window x:Class="PromptPaste.Views.Dialogs.LogViewerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="日志查看" Width="760" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F4F1EA"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#241F1A" />
        <SolidColorBrush x:Key="Muted" Color="#7A7167" />
        <SolidColorBrush x:Key="Line" Color="#E3DDD2" />
        <SolidColorBrush x:Key="Panel" Color="#FFFCF7" />
        <SolidColorBrush x:Key="Accent" Color="#B4532A" />

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Resources>

    <Border Margin="18" Padding="20" Background="{StaticResource Panel}" CornerRadius="18" BorderBrush="{StaticResource Line}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="应用日志" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" />
                <TextBlock Text="用于排查热键注册、快速候选弹窗和运行时错误。" Margin="0,5,0,0" Foreground="{StaticResource Muted}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="日志文件：" FontWeight="SemiBold" Foreground="{StaticResource Ink}" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="LogPathBox"
                         IsReadOnly="True"
                         Margin="8,0,0,0"
                         Padding="8,5"
                         Background="#FFF8EF"
                         BorderBrush="{StaticResource Line}"
                         BorderThickness="1"
                         Foreground="{StaticResource Muted}" />
            </Grid>

            <TextBox Grid.Row="2" x:Name="LogBox"
                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                     FontSize="12.5" Padding="12"
                     Background="#FFF8EF" BorderBrush="{StaticResource Line}" BorderThickness="1" />

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <TextBlock x:Name="CopiedHint" Text="已复制" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed" />
                <Button Content="刷新" Style="{StaticResource DialogButton}" Click="Refresh_Click" Margin="0,0,10,0" />
                <Button Content="复制日志" Style="{StaticResource DialogButton}" Click="CopyLog_Click" Margin="0,0,10,0" />
                <Button Content="打开目录" Style="{StaticResource DialogButton}" Click="OpenLogDir_Click" Margin="0,0,10,0" />
                <Button Content="关闭" Style="{StaticResource DialogButton}" IsCancel="True" Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
