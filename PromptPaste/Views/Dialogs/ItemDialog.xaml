<Window x:Class="PromptPaste.Views.Dialogs.ItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加内容" Width="620" Height="650"
        MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F4F1EA"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#241F1A" />
        <SolidColorBrush x:Key="Muted" Color="#7A7167" />
        <SolidColorBrush x:Key="Line" Color="#E3DDD2" />
        <SolidColorBrush x:Key="Panel" Color="#FFFCF7" />
        <SolidColorBrush x:Key="Accent" Color="#B4532A" />
        <SolidColorBrush x:Key="AccentDark" Color="#8F3F1E" />

        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="22,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        </Style>
    </Window.Resources>

    <Border Margin="18" Padding="20" Background="{StaticResource Panel}" CornerRadius="20" BorderBrush="{StaticResource Line}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock x:Name="HeaderTitle" Text="新建片段" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" />
                <TextBlock x:Name="HeaderSubtitle" Text="保存常用提示词、话术或文本模板" Margin="0,4,0,0" Foreground="{StaticResource Muted}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="标题" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="2,0,0,6" />
                <TextBox x:Name="TitleBox" Style="{StaticResource FieldTextBox}" FontSize="15" FontWeight="SemiBold" TextChanged="OnFieldChanged" />
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="分类（可多选）" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="2,0,0,6" />
                <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="12" Padding="10" MaxHeight="120">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="CategoriesPanel" />
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                <TextBlock Text="标签（用逗号分隔）" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="2,0,0,6" />
                <TextBox x:Name="TagsBox" Style="{StaticResource FieldTextBox}" />
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,10">
                <TextBlock Text="内容" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="2,0,0,6" />
                <TextBox x:Name="ContentBox" Style="{StaticResource FieldTextBox}" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="160" TextChanged="OnFieldChanged" />
            </StackPanel>

            <TextBlock Grid.Row="5" FontSize="12" Foreground="{StaticResource AccentDark}" Margin="2,0,0,16" Text="提示：使用 {{变量名}} 格式添加可替换变量" />

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource GhostButton}" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click" />
                <Button x:Name="SaveBtn" Content="保存" Style="{StaticResource PrimaryButton}" IsEnabled="False" Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
