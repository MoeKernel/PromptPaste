<Window x:Class="PromptPaste.Views.Dialogs.JsonFormatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JSON格式说明" Width="680" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F4F1EA"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#241F1A" />
        <SolidColorBrush x:Key="Muted" Color="#7A7167" />
        <SolidColorBrush x:Key="Line" Color="#E3DDD2" />
        <SolidColorBrush x:Key="Panel" Color="#FFFCF7" />
        <SolidColorBrush x:Key="Accent" Color="#B4532A" />

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Resources>

    <Border Margin="18" Padding="20" Background="{StaticResource Panel}" CornerRadius="18" BorderBrush="{StaticResource Line}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="导入 / 导出 JSON 格式" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" />
                <TextBlock Text="导出内容是片段数组；导入只支持新格式，分类路径和标签会自动创建。" Margin="0,5,0,0" Foreground="{StaticResource Muted}" />
            </StackPanel>

            <TextBlock Grid.Row="1" Margin="0,0,0,10" TextWrapping="Wrap" Foreground="{StaticResource Ink}">
                <Run Text="字段：" FontWeight="SemiBold" />
                <Run Text="id, title, content, itemType/ItemType, usageCount/UsageCount, lastUsed/LastUsed, createdAt/CreatedAt。日期建议使用 ISO 8601 字符串。" />
            </TextBlock>

            <TextBox Grid.Row="2" x:Name="ExampleBox"
                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                     FontSize="12.5" Padding="12"
                     Background="#FFF8EF" BorderBrush="{StaticResource Line}" BorderThickness="1" />

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <TextBlock x:Name="CopiedHint" Text="已复制" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed" />
                <Button Content="复制示例" Style="{StaticResource DialogButton}" Click="CopyExample_Click" Margin="0,0,10,0" />
                <Button Content="关闭" Style="{StaticResource DialogButton}" IsCancel="True" Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
