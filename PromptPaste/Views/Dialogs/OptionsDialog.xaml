<Window x:Class="PromptPaste.Views.Dialogs.OptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选项" Width="620" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F1EA"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#241F1A" />
        <SolidColorBrush x:Key="Muted" Color="#7A7167" />
        <SolidColorBrush x:Key="Line" Color="#E3DDD2" />
        <SolidColorBrush x:Key="Panel" Color="#FFFCF7" />
        <SolidColorBrush x:Key="Accent" Color="#B4532A" />

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="OptionTextBox" TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFF8EF" />
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
        </Style>
    </Window.Resources>

    <Border Margin="18" Padding="20" Background="{StaticResource Panel}" CornerRadius="18" BorderBrush="{StaticResource Line}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="选项" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Ink}" />
                <TextBlock Text="基础行为设置，保存后立即生效。" Margin="0,5,0,0" Foreground="{StaticResource Muted}" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="热键" FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,0,0,8" />
                <CheckBox x:Name="EnableHotKeyBox" Content="启用全局热键" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="唤出热键" VerticalAlignment="Center" Foreground="{StaticResource Muted}" />
                    <TextBox Grid.Column="1" x:Name="HotKeyBox" Style="{StaticResource OptionTextBox}"
                             IsReadOnly="True"
                             PreviewKeyDown="HotKeyBox_PreviewKeyDown"
                             GotKeyboardFocus="HotKeyBox_GotKeyboardFocus" />
                </Grid>
                <TextBlock Text="点击输入框后直接按组合键。至少需要一个 Ctrl / Alt / Shift / Win。"
                           FontSize="12" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="96,0,0,10" />
                <CheckBox x:Name="EnableQuickPasteHotKeyBox" Content="启用快速候选热键" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="候选热键" VerticalAlignment="Center" Foreground="{StaticResource Muted}" />
                    <TextBox Grid.Column="1" x:Name="QuickPasteHotKeyBox" Style="{StaticResource OptionTextBox}"
                             IsReadOnly="True"
                             PreviewKeyDown="HotKeyBox_PreviewKeyDown"
                             GotKeyboardFocus="HotKeyBox_GotKeyboardFocus" />
                </Grid>
                <TextBlock Text="默认 Ctrl+Alt+Space，在外部文本输入框中打开候选弹窗并插入片段。"
                           FontSize="12" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="96,0,0,18" />

                <Separator Margin="0,0,0,16" />

                <TextBlock Text="剪贴板" FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,0,0,8" />
                <CheckBox x:Name="EnableClipboardBox" Content="启用剪贴板监听并提示保存新内容" Margin="0,0,0,18" />

                <Separator Margin="0,0,0,16" />

                <TextBlock Text="窗口" FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,0,0,8" />
                <CheckBox x:Name="StartMinimizedBox" Content="启动时最小化到托盘" Margin="0,0,0,8" />
                <CheckBox x:Name="CloseToTrayBox" Content="关闭窗口时最小化到托盘" />

                <Separator Margin="0,16,0,16" />

                <TextBlock Text="数据与诊断" FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="当前数据库" VerticalAlignment="Center" Foreground="{StaticResource Muted}" />
                    <TextBox Grid.Column="1" x:Name="DatabasePathBox" Style="{StaticResource OptionTextBox}" IsReadOnly="True" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="配置文件" VerticalAlignment="Center" Foreground="{StaticResource Muted}" />
                    <TextBox Grid.Column="1" x:Name="SettingsPathBox" Style="{StaticResource OptionTextBox}" IsReadOnly="True" />
                </Grid>
                <WrapPanel Margin="96,0,0,0">
                    <Button Content="打开数据目录" Style="{StaticResource DialogButton}" Padding="12,6" Margin="0,0,8,8" Click="OpenDataDir_Click" />
                    <Button Content="打开日志目录" Style="{StaticResource DialogButton}" Padding="12,6" Margin="0,0,8,8" Click="OpenLogDir_Click" />
                    <Button Content="立即备份数据库" Style="{StaticResource DialogButton}" Padding="12,6" Margin="0,0,8,8" Click="BackupNow_Click" />
                </WrapPanel>
                <TextBlock x:Name="BackupHint" Text="" FontSize="12" Foreground="{StaticResource Accent}" TextWrapping="Wrap" Margin="96,0,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="确定" Style="{StaticResource DialogButton}" IsDefault="True" Click="Ok_Click" Margin="0,0,10,0" />
                <Button Content="取消" Style="{StaticResource DialogButton}" IsCancel="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
