<Window x:Class="PromptPaste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PromptPaste"
        xmlns:models="clr-namespace:PromptPaste.Models"
        Title="PromptPaste - 提示词与片段管理"
        Width="1040" Height="680" MinWidth="860" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei, sans-serif"
        FontSize="13"
        Background="#F4F1EA">
    <Window.Resources>
        <local:DateTimeConverter x:Key="DateConv" />
        <local:ContentPreviewConverter x:Key="PreviewConv" />
        <local:CountToVisConverter x:Key="CountVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolVis" />
        <BooleanToVisibilityConverter x:Key="BoolVis" />

        <SolidColorBrush x:Key="Ink" Color="#241F1A" />
        <SolidColorBrush x:Key="Muted" Color="#7A7167" />
        <SolidColorBrush x:Key="Line" Color="#E3DDD2" />
        <SolidColorBrush x:Key="Panel" Color="#FFFCF7" />
        <SolidColorBrush x:Key="Accent" Color="#B4532A" />
        <SolidColorBrush x:Key="AccentDark" Color="#8F3F1E" />

        <Style x:Key="TopMenu" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDark}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentDark}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF8EF" />
                                <Setter Property="Foreground" Value="{StaticResource Ink}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF8EF" />
                                <Setter Property="Foreground" Value="{StaticResource Ink}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavFilterButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF8EF" />
                                <Setter Property="Foreground" Value="{StaticResource Ink}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFCF7" />
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="12,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="PlaceholderText"
                                           Text="{TemplateBinding Tag}"
                                           Margin="12,0"
                                           VerticalAlignment="Center"
                                           Foreground="#A99F94"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CatItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFF8EF" />
                                <Setter Property="Foreground" Value="{StaticResource Ink}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F1DFD3" />
                                <Setter Property="Foreground" Value="{StaticResource AccentDark}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type models:CategoryNode}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding DisplayName}" />
        </HierarchicalDataTemplate>

        <Style x:Key="TreeExpanderToggle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <TextBlock x:Name="Glyph"
                                   Text="›"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Glyph" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Ink}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="AllowDrop" Value="True" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                    Width="1" Background="#D8CEC2"
                                    HorizontalAlignment="Center"
                                    Opacity="0.85" />
                            <Border Grid.Row="0" Grid.Column="0"
                                    Height="1" Background="#D8CEC2"
                                    VerticalAlignment="Center"
                                    Margin="9,0,0,0"
                                    Opacity="0.85" />

                            <Border x:Name="HeaderBorder"
                                    Grid.Row="0" Grid.Column="1"
                                    Background="Transparent"
                                    CornerRadius="9"
                                    Padding="{TemplateBinding Padding}">
                                <DockPanel LastChildFill="True">
                                    <ToggleButton x:Name="Expander"
                                                  DockPanel.Dock="Left"
                                                  Style="{StaticResource TreeExpanderToggle}"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press" />
                                    <ContentPresenter x:Name="PART_Header"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      Margin="2,0,0,0" />
                                </DockPanel>
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1" Grid.Column="1"
                                            Margin="13,0,0,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#FFF8EF" />
                                <Setter Property="Foreground" Value="{StaticResource Ink}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#F1DFD3" />
                                <Setter Property="Foreground" Value="{StaticResource AccentDark}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CardTemplate">
            <Border x:Name="Card"
                    Width="286" Height="230" Margin="8"
                    Focusable="False" FocusVisualStyle="{x:Null}"
                    Background="{StaticResource Panel}" CornerRadius="16"
                    BorderBrush="{StaticResource Line}" BorderThickness="1"
                    Padding="15"
                    MouseDown="Card_MouseDown"
                    PreviewMouseMove="Card_PreviewMouseMove"
                    MouseRightButtonUp="Card_MouseRightButtonUp">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.08" Color="#6A4A31" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource Ink}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource Muted}">
                                <Run Text="使用 " /><Run Text="{Binding UsageCount}" /><Run Text=" 次" />
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#F2E6D8" CornerRadius="9"
                                Padding="8,4" Margin="10,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding ItemType}" FontSize="11" Foreground="{StaticResource AccentDark}" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding Content, Converter={StaticResource PreviewConv}, ConverterParameter=110}"
                               FontSize="12.5" Foreground="#5F574E"
                               TextWrapping="Wrap" LineHeight="19"
                               VerticalAlignment="Top"
                               MaxHeight="76"
                               ClipToBounds="True"
                               Margin="0,0,0,10" />

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding Tags}"
                                  MaxHeight="34"
                                  ClipToBounds="True"
                                  Margin="0,0,0,10"
                                  Visibility="{Binding Tags.Count, Converter={StaticResource CountVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F3E2D1"
                                        BorderBrush="#E2C5AD"
                                        BorderThickness="1"
                                        CornerRadius="9"
                                        Padding="7,2"
                                        Margin="0,0,5,5">
                                    <TextBlock Text="{Binding}"
                                               FontSize="10.5"
                                               Foreground="{StaticResource AccentDark}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="78" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="3" VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="11" Foreground="#9A9187"
                                   VerticalAlignment="Center"
                                   Text="{Binding ., Converter={StaticResource DateConv}}" />
                        <StackPanel x:Name="QuickActions" Grid.Column="1" Orientation="Horizontal" Opacity="0">
                            <Button Content="{Binding PrimaryCardActionText, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}}"
                                    Tag="{Binding}" Style="{StaticResource CardActionButton}" Margin="4,0,0,0" Click="CopyCard_Click" />
                            <Button Content="{Binding SecondaryCardActionText, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}}"
                                    Tag="{Binding}" Style="{StaticResource CardActionButton}" Margin="4,0,0,0" Click="EditCard_Click" />
                            <Button Content="删除" Tag="{Binding}" Style="{StaticResource CardActionButton}" Margin="4,0,0,0" Click="DeleteCard_Click"
                                    Visibility="{Binding IsTrashView, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource InverseBoolVis}}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="Card" Property="IsMouseOver" Value="True">
                    <Setter TargetName="QuickActions" Property="Opacity" Value="1" />
                    <Setter TargetName="Card" Property="BorderBrush" Value="#D1B9A5" />
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFCF7" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,22,0">
                    <Border Width="32" Height="32" CornerRadius="10" Background="#241F1A" Margin="0,0,10,0">
                        <TextBlock Text="P" Foreground="#FFFCF7" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="PromptPaste" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Ink}" />
                        <TextBlock Text="片段 · 提示词 · 快速粘贴" FontSize="11" Foreground="{StaticResource Muted}" />
                    </StackPanel>
                </StackPanel>

                <Menu Grid.Column="1" Style="{StaticResource TopMenu}" VerticalAlignment="Center" Margin="0,0,18,0">
                    <MenuItem Header="文件">
                        <MenuItem Header="打开数据库..." Click="OpenDatabase_Click" />
                        <MenuItem x:Name="RecentDatabasesMenu" Header="最近数据库" />
                        <Separator />
                        <MenuItem Header="导入数据" Click="Import_Click" />
                        <MenuItem Header="导出数据" Click="Export_Click" />
                        <Separator />
                        <MenuItem Header="选项..." Click="Options_Click" />
                        <Separator />
                        <MenuItem Header="退出" Click="Exit_Click" />
                    </MenuItem>
                    <MenuItem Header="视图">
                        <MenuItem x:Name="IncludeChildrenMenuItem" Header="包含子分类" IsCheckable="True" IsChecked="True" Click="IncludeChildrenMenuItem_Click" />
                    </MenuItem>
                    <MenuItem Header="帮助">
                        <MenuItem Header="JSON格式说明" Click="JsonFormat_Click" />
                        <Separator />
                        <MenuItem Header="关于" Click="About_Click" />
                    </MenuItem>
                </Menu>

                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchBox" Style="{StaticResource SearchBoxStyle}"
                                 Tag="搜索标题或内容"
                                 ToolTip="搜索标题或内容" TextChanged="SearchBox_TextChanged" />
                        <Button Content="×"
                                Width="22" Height="22"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource Muted}"
                                Cursor="Hand"
                                ToolTip="清空搜索"
                                Click="ClearSearch_Click" />
                    </Grid>
                    <TextBox Grid.Column="1" x:Name="VarBox" Style="{StaticResource SearchBoxStyle}"
                             Margin="10,0,0,0"
                             Tag="变量值，如：公司名称"
                             ToolTip="在此输入值，双击含 {{变量名}} 的卡片时自动替换" />
                </Grid>

                <TextBlock Grid.Column="3" Text="{Binding ItemCount, StringFormat=共 {0} 条}" Foreground="{StaticResource Muted}"
                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0" />

                <Button Grid.Column="4" x:Name="AddBtn" Style="{StaticResource PrimaryButton}" Click="AddBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" FontSize="15" Margin="0,0,4,0" />
                        <TextBlock Text="新建片段" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F7F2EA" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0" Padding="14,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="4,0,0,10">
                        <TextBlock Text="分类" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Muted}" VerticalAlignment="Center" />
                        <Button Width="28" Height="26"
                                Padding="0"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                Style="{StaticResource GhostButton}"
                                Click="AddCategory_Click"
                                ToolTip="新增分类：选中分类时创建子分类，否则创建根分类">
                            <Viewbox Width="15" Height="15">
                                <Grid Width="16" Height="16">
                                    <Ellipse Stroke="{StaticResource Accent}" StrokeThickness="1.7" Fill="#FFF8EF" />
                                    <Path Data="M8,4.5 L8,11.5 M4.5,8 L11.5,8"
                                          Stroke="{StaticResource Accent}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </DockPanel>
                    <Button Grid.Row="1"
                            Content="全部"
                            Style="{StaticResource NavFilterButton}"
                            Margin="0,0,0,8"
                            Click="AllCategories_Click"
                            ToolTip="取消分类筛选，显示全部片段" />
                    <Button Grid.Row="2"
                            Content="未分类"
                            Style="{StaticResource NavFilterButton}"
                            Margin="0,0,0,8"
                            Click="Uncategorized_Click"
                            ToolTip="显示没有任何分类关系的片段" />
                    <DockPanel Grid.Row="3" Margin="0,0,0,8">
                        <Button Content="回收站"
                                Style="{StaticResource NavFilterButton}"
                                DockPanel.Dock="Left"
                                Width="112"
                                Click="Trash_Click"
                                ToolTip="查看已移入回收站的条目" />
                        <Button Content="清空"
                                Style="{StaticResource CardActionButton}"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                Click="ClearTrash_Click"
                                Visibility="{Binding IsTrashView, Converter={StaticResource BoolVis}}"
                                ToolTip="永久删除回收站中的所有条目" />
                    </DockPanel>
                    <TreeView Grid.Row="4" x:Name="CategoryTree"
                              ItemsSource="{Binding CategoryNodes}"
                              Background="Transparent" BorderThickness="0"
                              ItemContainerStyle="{StaticResource CategoryTreeItemStyle}"
                              PreviewMouseMove="CategoryTree_PreviewMouseMove"
                              PreviewMouseRightButtonDown="CategoryTree_PreviewMouseRightButtonDown"
                              Drop="CategoryTree_Drop"
                              SelectedItemChanged="CategoryTree_SelectedItemChanged" />
                    <StackPanel Grid.Row="5" Margin="0,14,0,0">
                        <TextBlock Text="标签筛选" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Muted}" Margin="4,0,0,8" />
                        <TextBox x:Name="TagSearchBox"
                                 Style="{StaticResource SearchBoxStyle}"
                                 MinHeight="32"
                                 Padding="8,4"
                                 ToolTip="输入标签关键字，回车添加第一个匹配标签"
                                 TextChanged="TagSearchBox_TextChanged"
                                 KeyDown="TagSearchBox_KeyDown" />
                        <ItemsControl ItemsSource="{Binding SelectedTags}" Margin="0,8,0,4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#EAD9C8" CornerRadius="11" Padding="8,3" Margin="0,0,6,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource AccentDark}" FontSize="12" VerticalAlignment="Center" />
                                            <Button Content="×"
                                                    Margin="6,0,0,0"
                                                    Padding="0"
                                                    Width="14" Height="14"
                                                    FontSize="12"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{StaticResource Muted}"
                                                    Cursor="Hand"
                                                    Click="RemoveTagChip_Click" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding TagSuggestions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}"
                                            HorizontalContentAlignment="Left"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="8,5"
                                            Margin="0,1"
                                            Foreground="{StaticResource Muted}"
                                            Cursor="Hand"
                                            Click="TagSuggestion_Click" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="18,16,18,0" Padding="14,10"
                        Background="#FFF8EF" BorderBrush="#E5CAB3" BorderThickness="1" CornerRadius="14"
                        Visibility="{Binding HasPendingClipboard, Converter={StaticResource BoolVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="检测到新的剪贴板内容" Foreground="{StaticResource Ink}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PendingClipboardPreview}" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="保存为片段" Style="{StaticResource PrimaryButton}" Padding="12,6" Margin="12,0,0,0" Click="SavePendingClipboard_Click" />
                        <Button Grid.Column="2" Content="忽略" Style="{StaticResource GhostButton}" Padding="12,6" Margin="8,0,0,0" Click="DismissPendingClipboard_Click" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <TextBlock Text="{Binding EmptyStateText}" FontSize="16" Foreground="#B9AEA2"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding Items.Count, Converter={StaticResource CountVis}, ConverterParameter=empty}" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False" FocusVisualStyle="{x:Null}"
                                  Padding="12,8">
                        <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource CardTemplate}"
                                      Focusable="False" FocusVisualStyle="{x:Null}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Background="#241F1A"
                            CornerRadius="16"
                            Padding="16,9"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,18"
                            Opacity="0.94"
                            Visibility="{Binding HasToastMessage, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{Binding ToastMessage}" Foreground="#FFFCF7" FontWeight="SemiBold" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
